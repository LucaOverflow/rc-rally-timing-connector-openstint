{
  "name": "rc-rally-timing-connector-openstint",
  "version": "1.0.0",
  "description": "This program will integrate openstint decoders with rc-rally-timing",
  "main": "src/index.ts",
  "bin": "dist/transpiled/index.js",
  "pkg": {
    "targets": [
      "node22-linux-x64",
      "node22-linux-arm64",
      "node22-macos-x64",
      "node22-macos-arm64",
      "node22-win-x64",
      "node22-win-arm64"
    ],
    "outputPath": "dist",
    "assets": [
      "node_modules/zeromq/**"
    ]
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@yao-pkg/pkg": "^6.21.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "build:tsc": "npx tsc",
    "build:pkg": "npx pkg . --sea",
    "build": "npm run build:tsc && npm run build:pkg",
    "dev": "npx tsx src/",
    "start": "node dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LucaOverflow/rc-rally-timing-connector-openstint.git"
  },
  "author": "LucaOverflow",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/LucaOverflow/rc-rally-timing-connector-openstint/issues"
  },
  "homepage": "https://github.com/LucaOverflow/rc-rally-timing-connector-openstint#readme",
  "dependencies": {
    "commander": "^15.0.0",
    "pocketbase": "^0.27.0",
    "zeromq": "^6.5.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "zeromq@6.5.0": true,
    "fsevents@2.3.3": true
  }
}
